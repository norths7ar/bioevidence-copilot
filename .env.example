# Core paths
DATA_DIR=data/corpora/demo
LOG_LEVEL=INFO
EMBEDDING_CACHE_DIR=data/cache

# Optional PubMed contact metadata
PUBMED_EMAIL=
PUBMED_TOOL_NAME=BioEvidence Copilot

# Embedding backend configuration
# Choose one provider and fill in the generic EMBEDDING_* fields.
# Qwen Embedding
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BATCH_SIZE=10
# MiMo-compatible embedding provider
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://...
# EMBEDDING_MODEL=...
# EMBEDDING_DIMENSIONS=...
# EMBEDDING_BATCH_SIZE=10

# Agent backend configuration
# Choose one provider and fill in the generic AGENT_* fields.
# DeepSeek
# AGENT_API_KEY=sk-...
# AGENT_BASE_URL=https://api.deepseek.com/v1
# AGENT_MODEL=deepseek-chat
# Qwen Chat
# AGENT_API_KEY=sk-...
# AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AGENT_MODEL=qwen-turbo
# MiMo
# AGENT_API_KEY=sk-...
# AGENT_BASE_URL=https://api.xiaomimimo.com/v1
# AGENT_MODEL=mimo-v2.5-pro

# Agent runtime parameters
AGENT_MAX_ITERATIONS=3
AGENT_MAX_OUTPUT_TOKENS=8192
AGENT_TEMPERATURE=0.2

# Agent stopping thresholds
AGENT_MIN_RELEVANCE_SCORE=0.6
AGENT_MIN_UNIQUE_PMIDS=3

# Optional query-focused semantic extraction. `legacy` preserves the original
# evidence rows; `rules`, `prompted`, and `local` attach the validated v1
# structured extraction fields. Optional model backends fall back to rules.
EXTRACTION_BACKEND=legacy
EXTRACTION_API_KEY=
EXTRACTION_BASE_URL=
EXTRACTION_MODEL=
EXTRACTION_ADAPTER_PATH=
EXTRACTION_MAX_SEQ_LENGTH=4096
EXTRACTION_MAX_OUTPUT_TOKENS=1024

# Optional Hetionet / Neo4j discovery layer
GRAPH_ENABLED=false
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_MAX_PATHS=20
GRAPH_MAX_EXPANSION_QUERIES=3
