# Core paths
BIOEVIDENCE_DATA_DIR=data
BIOEVIDENCE_LOG_LEVEL=INFO
BIOEVIDENCE_EMBEDDING_CACHE_DIR=data/cache

# Optional PubMed contact metadata
PUBMED_EMAIL=
PUBMED_TOOL_NAME=BioEvidence Copilot

# Embedding backend configuration
# Choose one provider and fill in the generic BIOEVIDENCE_EMBEDDING_* fields.
# Qwen Embedding
# BIOEVIDENCE_EMBEDDING_API_KEY=sk-...
# BIOEVIDENCE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BIOEVIDENCE_EMBEDDING_MODEL=text-embedding-v4
# BIOEVIDENCE_EMBEDDING_DIMENSIONS=1024
# MiMo-compatible embedding provider
# BIOEVIDENCE_EMBEDDING_API_KEY=sk-...
# BIOEVIDENCE_EMBEDDING_BASE_URL=https://...
# BIOEVIDENCE_EMBEDDING_MODEL=...
# BIOEVIDENCE_EMBEDDING_DIMENSIONS=...

# Agent backend configuration
# Choose one provider and fill in the generic BIOEVIDENCE_AGENT_* fields.
# DeepSeek
# BIOEVIDENCE_AGENT_API_KEY=sk-...
# BIOEVIDENCE_AGENT_BASE_URL=https://api.deepseek.com/v1
# BIOEVIDENCE_AGENT_MODEL=deepseek-chat
# Qwen Chat
# BIOEVIDENCE_AGENT_API_KEY=sk-...
# BIOEVIDENCE_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BIOEVIDENCE_AGENT_MODEL=qwen-turbo
# MiMo
# BIOEVIDENCE_AGENT_API_KEY=sk-...
# BIOEVIDENCE_AGENT_BASE_URL=https://api.xiaomimimo.com/v1
# BIOEVIDENCE_AGENT_MODEL=mimo-v2-pro

# Agent runtime parameters
BIOEVIDENCE_AGENT_MAX_ITERATIONS=3
BIOEVIDENCE_AGENT_MAX_OUTPUT_TOKENS=800
BIOEVIDENCE_AGENT_TEMPERATURE=0.2

# Agent stopping thresholds
BIOEVIDENCE_AGENT_MIN_RELEVANCE_SCORE=0.6
BIOEVIDENCE_AGENT_MIN_UNIQUE_PMIDS=3
